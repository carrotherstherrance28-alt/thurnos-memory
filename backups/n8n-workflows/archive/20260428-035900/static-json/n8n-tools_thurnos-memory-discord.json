      "id": "m0000001-0001-0001-0001-000000000001",
      "name": "Discord Trigger",
      "type": "n8n-nodes-base.discordTrigger",
      "typeVersion": 1,
      "position": [240, 300],
      "credentials": {
        "discordBotApi": {
          "id": "",
          "name": "Thurnos Prime Bot"
        }
      }
