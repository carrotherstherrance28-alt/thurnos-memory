    {
      "parameters": {
        "jsCode": "const results = $input.all();\nconst cmd = $('Parse Command').item.json;\nconst existing = results[0]?.json;\n\nreturn [{\n  json: {\n    exists: !!(existing && existing.id),\n    recordId: existing?.id || null,\n    key: cmd.key,\n    value: cmd.value,\n    client: cmd.client,\n    category: cmd.category,\n    channelId: cmd.channelId\n  }\n}];"
      },
