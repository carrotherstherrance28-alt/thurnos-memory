    {
      "parameters": {
        "jsCode": "const msg = $input.first().json;\nconst content = (msg.content || '').trim();\nconst channelId = msg.channelId || msg.channel_id || '';\n\nif (!content.startsWith('!')) return [];\n\nconst parts = content.slice(1).split(' ');\nconst command = parts[0].toLowerCase();\n\nlet key = '';\nlet value = '';\nlet client = '';\nlet category = 'general';\n\nif (command === 'remember') {\n  // !remember [key] [value]\n  key = parts[1] || '';\n  value = parts.slice(2).join(' ');\n} else if (command === 'recall') {\n  // !recall [key]\n  key = parts[1] || '';\n} else if (command === 'forget') {\n  // !forget [key]\n  key = parts[1] || '';\n}\n\nreturn [{ json: { command, key, value, client, category, channelId, raw: content } }];"
      },
      "id": "m0000001-0002-0002-0002-000000000002",
      "name": "Parse Command",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 300]
    },
    {
      "parameters": {
        "rules": {
          "rules": [
            {
              "conditions": {
                "conditions": [
                  {
                    "leftValue": "={{ $json.command }}",
                    "rightValue": "remember",
                    "operator": { "type": "string", "operation": "equals" }
                  }
                ]
              },
              "renameOutput": true,
              "outputKey": "remember"
            },
            {
              "conditions": {
                "conditions": [
                  {
                    "leftValue": "={{ $json.command }}",
                    "rightValue": "recall",
                    "operator": { "type": "string", "operation": "equals" }
                  }
                ]
              },
              "renameOutput": true,
              "outputKey": "recall"
            },
            {
              "conditions": {
                "conditions": [
                  {
                    "leftValue": "={{ $json.command }}",
                    "rightValue": "forget",
                    "operator": { "type": "string", "operation": "equals" }
                  }
                ]
              },
              "renameOutput": true,
              "outputKey": "forget"
            }
          ]
        },
        "fallbackOutput": "extra"
      },
      "id": "m0000001-0003-0003-0003-000000000003",
      "name": "Route Command",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
